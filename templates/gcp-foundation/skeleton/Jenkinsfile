pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 60, unit: 'MINUTES')
  }

  environment {
    TF_IN_AUTOMATION   = 'true'
    TF_INPUT           = 'false'
  }

  stages {

    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Verify Environment') {
      steps {
        sh '''
          echo "====================================="
          echo "Verifying build environment..."
          echo "Working Directory:"
          pwd
          echo "====================================="
          echo "Repository Contents:"
          ls -la
          echo "====================================="
          echo "Terraform Configuration Files:"
          ls -la *.tf || true
        '''
      }
    }

    stage('Verify GCP Authentication') {
      steps {
        sh '''
          echo "====================================="
          echo "Verifying GCP authentication..."
          echo "Active GCP Service Account:"
          gcloud auth list --filter=status:ACTIVE --format="value(account)"
          echo "====================================="
          echo "Active GCP Project:"
          gcloud config get-value project || true
        '''
      }
    }

    stage('Terraform Version') {
      steps {
        sh '''
          echo "====================================="
          echo "Fetching Terraform version information..."
          terraform version
        '''
      }
    }

    stage('Terraform Format Check') {
      steps {
        sh '''
          echo "====================================="
          echo "Running Terraform format check..."
          terraform fmt -recursive -check
          echo "Format check passed successfully."
        '''
      }
    }

    stage('Terraform Init') {
      steps {
        sh '''
          echo "====================================="
          echo "Initializing Terraform working directory..."
          terraform init -reconfigure
          echo "Terraform initialization complete."
        '''
      }
    }

    stage('Terraform Validate') {
      steps {
        sh '''
          echo "====================================="
          echo "Validating Terraform configuration files..."
          terraform validate
          echo "Terraform validation passed successfully."
        '''
      }
    }

    stage('Terraform Plan') {
      steps {
        sh '''
          echo "====================================="
          echo "Generating Terraform execution plan..."
          terraform plan -out=tfplan
          echo "Terraform plan generated successfully. Review the plan before proceeding."
        '''
      }
    }

    stage('Approve Apply') {
      steps {
        script {
          try {
            timeout(time: 30, unit: 'MINUTES') {
              input message: 'Review the Terraform plan above. Approve to proceed with infrastructure provisioning.',
                    ok: 'Approve & Deploy'
            }
          } catch (err) {
            currentBuild.result = 'ABORTED'
            error('Deployment approval was not received within the allotted time. Pipeline aborted.')
          }
        }
      }
    }

    stage('Terraform Apply') {
      steps {
        sh '''
          echo "====================================="
          echo "Applying Terraform configuration..."
          echo "Provisioning GCP infrastructure resources..."
          terraform apply -auto-approve tfplan
          echo "====================================="
          echo "Infrastructure provisioned successfully."
        '''
      }
    }

    stage('Terraform Outputs') {
      steps {
        sh '''
          echo "====================================="
          echo "Fetching Terraform output values..."
          terraform output -json || true
        '''
      }
    }

    stage('Wait Before Destroy') {
      steps {
        script {
          echo "====================================="
          echo "Infrastructure provisioning complete."
          echo "Scheduled auto-destroy will commence in 30 minutes."
          echo "All resources created by this pipeline will be permanently deleted."
          sleep(time: 30, unit: 'MINUTES')
        }
      }
    }

    stage('Approve Destroy') {
      steps {
        script {
          try {
            timeout(time: 10, unit: 'MINUTES') {
              input message: 'WARNING: All infrastructure resources created by this pipeline will be permanently destroyed. This action is irreversible. Confirm to proceed.',
                    ok: 'Confirm Destroy'
            }
          } catch (err) {
            currentBuild.result = 'ABORTED'
            echo "Destroy approval not received. Infrastructure resources are still active."
            echo "Please destroy resources manually to avoid unnecessary costs."
            error('Destroy stage was not approved. Pipeline aborted.')
          }
        }
      }
    }

    stage('Terraform Destroy') {
      steps {
        sh '''
          echo "====================================="
          echo "Initiating Terraform destroy..."
          echo "Decommissioning all provisioned GCP infrastructure resources..."
          terraform destroy -auto-approve
          echo "====================================="
          echo "All infrastructure resources have been successfully destroyed."
        '''
      }
    }

  }

  post {

    success {
      echo '====================================='
      echo 'Pipeline executed successfully.'
      echo 'All infrastructure resources have been provisioned and decommissioned as scheduled.'
    }

    failure {
      node('') {
        echo '====================================='
        echo 'Pipeline execution failed.'
        echo 'Infrastructure resources may still be active on GCP.'
        echo 'Please review the logs and perform manual cleanup using: terraform destroy'
      }
    }

    aborted {
      node('') {
        echo '====================================='
        echo 'Pipeline was aborted.'
        echo 'Infrastructure resources may still be active on GCP.'
        echo 'Please verify the resource state and perform manual cleanup if required.'
      }
    }

    always {
      node('') {
        echo '====================================='
        echo 'Archiving build artifacts...'
        archiveArtifacts artifacts: 'tfplan', allowEmptyArchive: true
        echo '====================================='
        echo 'Build post-processing complete. Cleaning workspace...'
        cleanWs()
      }
    }

  }
}